# ── Zoho Books API (server-side only — add these in Vercel Environment Variables) ──
# These are NEVER prefixed with VITE_ because they must NOT be exposed to the browser.

ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOHO_REFRESH_TOKEN=1000.xxxxxxxxxxxxx...   (see setup guide below)
ZOHO_ORG_ID=123456789                      (Zoho Books → Settings → Organization Profile)

# Optional: change if your Zoho account is in EU / India / Australia
# ZOHO_AUTH_DOMAIN=https://accounts.zoho.eu
# ZOHO_API_DOMAIN=https://www.zohoapis.eu

# ── Wholesale clients (server-side only) ────────────────────────────────────────
# JSON array of wholesale client credentials.
# Add/remove clients here, then redeploy.
WHOLESALE_CLIENTS=[{"email":"client@company.com","password":"theirpassword","name":"John Smith","company":"Acme Corp"}]
